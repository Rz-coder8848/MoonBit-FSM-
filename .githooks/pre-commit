#!/bin/sh
#
# Pre-commit hook to format MoonBit code
#

echo "Formatting MoonBit code..."
moon fmt

if [ $? -ne 0 ]; then
    echo "Formatting failed. Please fix before committing."
    exit 1
fi

echo "Running static tests..."
moon test

if [ $? -ne 0 ]; then
    echo "Tests failed. Please fix before committing."
    exit 1
fi

exit 0
